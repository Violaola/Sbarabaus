---
import "bootstrap/dist/css/bootstrap.min.css";
import "bootstrap-icons/font/bootstrap-icons.css";
import "../../styles/main.scss";
import "../../styles/footer.scss";
import innerStylesUrl from "../../styles/inner-pages.scss?url";
import menuScriptUrl from "../scripts/menu.js?url";
import mainScriptUrl from "../scripts/main.js?url";
import innerPagesScriptUrl from "../scripts/inner-pages.js?url";

interface Props {
  title?: string;
  description?: string;
  useInnerPagesScript?: boolean;
  useInnerStyles?: boolean;
}

const {
  title = "Panebarco",
  description = "",
  useInnerPagesScript = false,
  useInnerStyles = false,
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Sofia+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Margarine&display=swap" rel="stylesheet" />
    {useInnerStyles && <link rel="stylesheet" href={innerStylesUrl} />}
  </head>
  <body class:list={[useInnerStyles && "inner-page"]}>
    <slot />

    <script type="module" src={menuScriptUrl}></script>
    <script type="module" src={mainScriptUrl}></script>

    {useInnerPagesScript && (
      <script type="module" src={innerPagesScriptUrl}></script>
    )}
  </body>
</html>
