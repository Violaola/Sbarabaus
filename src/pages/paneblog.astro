---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Paneblog - Panebarco"
  useInnerPagesScript={true}
  useInnerStyles={true}
  headerProps={{ containerClass: "hero-fluid" }}
>
    <main>
      <section class="page-hero">
        <video autoplay muted loop playsinline preload="metadata" aria-hidden="true">
          <source src="/images/1021768637.mp4" type="video/mp4">
        </video>
        <div class="page-hero-content">
          <div class="page-hero-text">
            <p class="page-hero-bgword">PENSIERI</p>
            <h1 class="page-hero-title">PANEBLOG</h1>
            <p class="page-hero-subtitle">Appunti, processi e dietro le quinte del nostro lavoro</p>
          </div>
          <div class="page-hero-media">
            <img src="/images/testata img.png" alt="Paneblog">
          </div>
        </div>
      </section>
  
      <section class="page-main">
        <div class="container">
          <h2>Pensieri che diventano storie</h2>
        </div>
      </section>
    </main>
</Layout>
