---
import Layout from "../layouts/Layout.astro";
import HeroStyHome from "../components/HeroStyHome.astro";
import OriginalsShowcase from "../components/OriginalsShowcase.astro";
import mainScriptUrl from "../scripts/main.js?url";

const serviceAreas = [
  {
    title: "Commercials",
    href: "/servizi/commercials",
    image: "/images/servizi-cover-01-340x487.png",
    summary: "Spot, branded content e video pensati per raccontare, spiegare, promuovere e coinvolgere.",
  },
  {
    title: "Post-produzione",
    href: "/servizi/post-produzione",
    image: "/images/servizi-cover-02-340x487.jpg",
    summary: "Color, compositing, VFX e finishing per dare ritmo, atmosfera e precisione alle immagini.",
  },
  {
    title: "Service",
    href: "/servizi/service",
    image: "/images/servizi-cover-03-340x487.jpg",
    summary: "Supporto produttivo e operativo per accompagnare ogni fase del lavoro, dalla partenza alla consegna.",
  },
  {
    title: "...e tanto altro",
    href: "/servizi/e-tanto-altro",
    image: "/images/servizi-cover-01-340x487.png",
    summary: "Progetti speciali, sperimentazioni e idee laterali che allargano il nostro modo di lavorare.",
  },
] as const;
---

<Layout
  title="Panebarco - Homepage"
  description="Homepage Panebarco"
  headerProps={{ darkmode: false }}
>
    <main>
      <HeroStyHome id="studio" className="hero-wrap" showSlider={true} />
  
      <!-- Sezione "Siamo" con testo istituzionale e CTA -->
      <section class="section-space">
        <div class="container">
          <h2 class="section-title">
            SIAMO <br>
            <span
              id="typing-text"
              class="accent typing-text"
              data-words="i Panebarcos|uno studio di animazione|una casa di produzione indipendente|un&rsquo;agenzia creativa|una bottega multimediale|una famiglia tra cartoon e realt&agrave;"
              aria-live="polite"
            ></span>
          </h2>
          <div class="row g-4 align-items-center">
            <div class="col-lg-6">
              <p class="about-text">
                Sviluppiamo progetti originali e affianchiamo altre produzioni con
                service, vfx e post-produzione, lavorando in modo artigianale,
                senza scorciatoie e con molta cura.
                <br><br>
                A portare avanti tutto questo dal 1995, c&rsquo;&egrave; una
                famiglia un po&rsquo; stramba, sospesa tra cartoon e realt&agrave;,
                che da Ravenna continua a fare questo mestiere con la stessa
                curiosit&agrave; di sempre.
              </p>
              <div class="d-flex flex-wrap gap-2 mt-4 justify-content-center justify-content-lg-start">
                <a href="#" class="btn btn-cta btn-cta--blue btn-pill">SCOPRI IL TEAM</a>
                <a href="#" class="btn btn-cta btn-cta--orange btn-pill">SCOPRI DI PIU</a>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="team-blob">
                <img src="/images/siamo-teams.png" alt="I Panebarcos">
              </div>
            </div>
          </div>
        </div>
      </section>
  
      <!-- Cards servizi -->
      <section id="servizi" class="section-space section-space--soft services-home-cards">
        <div class="container">
          <h2 class="section-title section-title-reveal">
            <span class="section-title-text">SERVIZI</span>
            <img class="section-title-sticker" src="/images/cose che sappiamo fare.png" alt="" aria-hidden="true">
          </h2>
          <div class="row g-4 services-box-grid">
            {serviceAreas.map((service) => (
              <div class="col-12 col-md-6 col-lg-3">
                <a
                  class="services-box-link d-block text-decoration-none"
                  href={service.href}
                  aria-label={`Apri la pagina ${service.title}`}
                >
                  <article class="services-box-card" style={`--service-bg:url('${service.image}');`}>
                    <div class="services-box-card__overlay"></div>
                    <div class="services-box-card__content">
                      <h3>{service.title}</h3>
                      <p>{service.summary}</p>
                    </div>
                  </article>
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>
  
      <!-- Slider Panebarco Originals -->
      <OriginalsShowcase />
  
      <!-- Griglia portfolio -->
      <section id="portfolio" class="section-space">
        <div class="container originals-stage portfolio-container">
          <h2 class="section-title section-title-reveal">
          <span class="section-title-text">PORTFOLIO</span>
          <img class="section-title-sticker" src="/images/cose belle che abbiamo fatto.png" alt="" aria-hidden="true">
        </h2>
          <div class="portfolio-grid">
            <article class="portfolio-item top-left">
              <img src="/images/portfolio-cover-01-695x391.jpg" alt="Progetto portfolio 1">
              <div class="portfolio-tags">
                <span class="portfolio-tag">2D</span>
                <span class="portfolio-tag">Animazione</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto 01</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
            <article class="portfolio-item top-right">
              <img src="/images/portfolio-cover-02-695x391.jpg" alt="Progetto portfolio 2">
              <div class="portfolio-tags">
                <span class="portfolio-tag">3D</span>
                <span class="portfolio-tag">VFX</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto 02</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
            <a
              class="portfolio-item bottom-left text-decoration-none"
              href="/portfolio/vita-dura-per-gli-orsi-marsicani"
              aria-label="Apri il progetto Vita dura per gli Orsi Marsicani"
            >
              <img src="/images/portfolio-cover-03-695x391.jpg" alt="Progetto portfolio 3">
              <div class="portfolio-tags">
                <span class="portfolio-tag">Regia</span>
                <span class="portfolio-tag">2D</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Vita dura per gli Orsi Marsicani</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </a>
            <article class="portfolio-item bottom-right">
              <img src="/images/portfolio-cover-04-695x391.jpg" alt="Progetto portfolio 4">
              <div class="portfolio-tags">
                <span class="portfolio-tag">Animazione</span>
                <span class="portfolio-tag">3D</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto 04</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
            <article class="portfolio-item wide">
              <img src="/images/portfolio-cover-05-695x391.jpg" alt="Progetto portfolio in evidenza">
              <div class="portfolio-tags">
                <span class="portfolio-tag">Regia</span>
                <span class="portfolio-tag">VFX</span>
                <span class="portfolio-tag">3D</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto In Evidenza</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
          </div>
          <div class="text-center mt-4">
            <a href="#" class="btn btn-cta btn-cta--blue btn-pill portfolio-cta">SCOPRI DI PI&Ugrave;</a>
          </div>
        </div>
      </section>
  
      <!-- Anteprima Paneblog -->
      <section id="paneblog" class="section-space section-space--tight">
        <div class="container">
          <h2 class="section-title section-title-reveal">
          <span class="section-title-text">PANEBLOG</span>
          <img class="section-title-sticker" src="/images/pensieri che ci frullano in testa.png" alt="" aria-hidden="true">
        </h2>
          <div class="row g-3">
            <div class="col-12 col-sm-6 col-lg-4">
              <article class="card blog-card h-100">
                <img src="/images/paneblog-cover-01-356x217.png" alt="Articolo blog 1">
                <div class="card-body">
                  <h3 class="blog-title">Dietro le quinte di Caramelle</h3>
                  <p class="blog-date">21 FEB 2026</p>
                  <p class="blog-abstract">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer in cursus erat.</p>
                  <a class="blog-link" href="#">
                    Leggi di pi&ugrave; <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
              <article class="card blog-card h-100">
                <img src="/images/paneblog-cover-02-356x217.png" alt="Articolo blog 2">
                <div class="card-body">
                  <h3 class="blog-title">Pipeline 3D: workflow interno</h3>
                  <p class="blog-date">15 FEB 2026</p>
                  <p class="blog-abstract">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer in cursus erat.</p>
                  <a class="blog-link" href="#">
                    Leggi di pi&ugrave; <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
              <article class="card blog-card h-100">
                <img src="/images/paneblog-cover-03-356x217.png" alt="Articolo blog 3">
                <div class="card-body">
                  <h3 class="blog-title">Regia e animazione: come si integrano</h3>
                  <p class="blog-date">08 FEB 2026</p>
                  <p class="blog-abstract">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer in cursus erat.</p>
                  <a class="blog-link" href="#">
                    Leggi di pi&ugrave; <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
          </div>
          <div class="text-center mt-4">
            <a href="#" class="btn btn-cta btn-cta--blue btn-pill">LEGGI IL PANEBLOG</a>
          </div>
        </div>
      </section>
    </main>
    <script type="module" src={mainScriptUrl}></script>
</Layout>
