---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
---

<BaseLayout title="Panebarco - Homepage" description="Homepage Panebarco" useInnerPagesScript={false}>
  <SiteHeader />
  <MenuOverlay />
    <main>
      <section id="studio" class="hero-wrap">
        <div class="container-fluid hero-fluid px-3 px-md-4 px-lg-5">
          <div class="hero-card">
            <video class="hero-bg-video" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
              <source src="/images/1021768637.mp4" type="video/mp4">
            </video>
            <h1>Ciao!</h1>
            <p>Animazione, creativit&agrave; e un pizzico di magia digitale.</p>
            <a href="#" class="btn btn-cta btn-cta--blue hero-cta">
              <i class="bi bi-play-fill" aria-hidden="true"></i> Scopri cosa facciamo
            </a>
            <div class="chat-pop" role="region" aria-label="Anteprima chat">
              <div class="chat-header">
                <span id="chatSliderDate" class="chat-date">15/01/2026</span>
                <div class="chat-fixed">
                  <span class="chat-chip">che fate?</span>
                  <span class="chat-avatar chat-avatar--fixed">
                    <img src="/images/avatar-che-fate-00.png" alt="Avatar fisso">
                  </span>
                </div>
              </div>
              <div class="chat-message-row">
                <span class="chat-avatar chat-avatar--slider">
                  <img id="chatSliderAvatarImg" src="https://picsum.photos/seed/chat-slider-1/140/140" alt="Avatar personaggio">
                </span>
                <div class="chat-body">
                  <strong id="chatSliderTitle">Titolo del messaggio</strong>
                  <p id="chatSliderText">
                    Aenean vel tortor aliquet, lobortis ligula a, tempus metus.
                    Vestibulum aliquet, ante sit amet.
                  </p>
                </div>
              </div>
              <div class="chat-controls">
                <button id="chatSliderPrev" class="chat-nav" type="button" aria-label="Messaggio precedente">
                  <i class="bi bi-chevron-left"></i>
                </button>
                <div id="chatSliderDots" class="chat-dots" aria-label="Navigazione messaggi"></div>
                <button id="chatSliderNext" class="chat-nav" type="button" aria-label="Messaggio successivo">
                  <i class="bi bi-chevron-right"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>
  
      <section class="section-space">
        <div class="container">
          <h2 class="section-title">
            SIAMO <br>
            <span
              id="typing-text"
              class="accent typing-text"
              data-words="i Panebarcos|uno studio di animazione|una casa di produzione indipendente|un&rsquo;agenzia creativa|una bottega multimediale|una famiglia tra cartoon e realt&agrave;"
              aria-live="polite"
            ></span>
          </h2>
          <div class="row g-4 align-items-center">
            <div class="col-lg-6">
              <p class="about-text">
                Sviluppiamo progetti originali e affianchiamo altre produzioni con
                service, vfx e post-produzione, lavorando in modo artigianale,
                senza scorciatoie e con molta cura.
                <br><br>
                A portare avanti tutto questo dal 1995, c&rsquo;&egrave; una
                famiglia un po&rsquo; stramba, sospesa tra cartoon e realt&agrave;,
                che da Ravenna continua a fare questo mestiere con la stessa
                curiosit&agrave; di sempre.
              </p>
              <div class="d-flex flex-wrap gap-2 mt-4">
                <a href="#" class="btn btn-cta btn-cta--blue btn-pill">SCOPRI IL TEAM</a>
                <a href="#" class="btn btn-cta btn-cta--orange btn-pill">SCOPRI DI PIU</a>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="team-blob">
                <img src="/images/siamo-teams.png" alt="I Panebarcos">
              </div>
            </div>
          </div>
        </div>
      </section>
  
      <section id="servizi" class="section-space pt-2">
        <div class="container">
          <h2 class="section-title section-title-reveal">
          <span class="section-title-text">SERVIZI</span>
          <img class="section-title-sticker" src="/images/cose che sappiamo fare.png" alt="" aria-hidden="true">
        </h2>
          <div class="row g-4 justify-content-center">
            <div class="col-12 col-lg-6 col-xxl-4 service-col">
              <article class="service-card" style="--service-bg:url('/images/servizi-cover-01-340x487.png');">
                <h3>Commercials</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer posuere erat a ante venenatis dapibus.</p>
              </article>
            </div>
            <div class="col-12 col-lg-6 col-xxl-4 service-col">
              <article class="service-card" style="--service-bg:url('/images/servizi-cover-02-340x487.jpg');">
                <h3>Post-produzione</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Curabitur blandit tempus porttitor sed posuere.</p>
              </article>
            </div>
            <div class="col-12 col-lg-6 col-xxl-4 service-col">
              <article class="service-card" style="--service-bg:url('/images/servizi-cover-03-340x487.jpg');">
                <h3>Service</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Maecenas faucibus mollis interdum et fermentum.</p>
              </article>
            </div>
          </div>
        </div>
      </section>
  
      <section id="originals" class="dark-band originals-parallax" style="--originals-bg-image:url('/images/panebarco-originals-bg.jpg');">
        <div class="originals-sticky">
          <div class="container originals-stage">
            <h2 class="visually-hidden">Panebarco Originals</h2>
            <img class="originals-title-logo" src="/images/panebarco originals logo.png" alt="Panebarco Originals">
            <div id="originalsCarousel" class="originals-carousel">
              <div class="originals-layout">
                <article id="originalFeaturedCard" class="original-featured">
                  <div class="featured-content">
                    <h4 id="originalFeaturedTitle"></h4>
                    <img class="originals-logo-mark" src="/images/panebarco originals logo.png" alt="">
                    <a id="originalFeaturedBtn" href="#" class="btn btn-cta btn-cta--blue original-more-btn">Scopri di pi&ugrave;</a>
                  </div>
                </article>
                <article id="originalSideCard1" class="original-side-card">
                  <div class="side-content">
                    <h4 id="originalSideTitle1"></h4>
                    <img class="originals-logo-mark" src="/images/panebarco originals logo.png" alt="">
                  </div>
                </article>
                <article id="originalSideCard2" class="original-side-card">
                  <div class="side-content">
                    <h4 id="originalSideTitle2"></h4>
                    <img class="originals-logo-mark" src="/images/panebarco originals logo.png" alt="">
                  </div>
                </article>
              </div>
  
              <div class="originals-nav-bottom">
                <button id="originalsPrev" class="originals-arrow" type="button" aria-label="Slide precedente">
                  <i class="bi bi-arrow-left"></i>
                </button>
                <button id="originalsNext" class="originals-arrow" type="button" aria-label="Slide successiva">
                  <i class="bi bi-arrow-right"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>
  
      <section id="portfolio" class="section-space">
        <div class="container originals-stage portfolio-container">
          <h2 class="section-title section-title-reveal">
          <span class="section-title-text">PORTFOLIO</span>
          <img class="section-title-sticker" src="/images/cose belle che abbiamo fatto.png" alt="" aria-hidden="true">
        </h2>
          <div class="portfolio-grid">
            <article class="portfolio-item top-left">
              <img src="/images/portfolio-cover-01-695x391.jpg" alt="Progetto portfolio 1">
              <div class="portfolio-tags">
                <span class="portfolio-tag">2D</span>
                <span class="portfolio-tag">Animazione</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto 01</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
            <article class="portfolio-item top-right">
              <img src="/images/portfolio-cover-02-695x391.jpg" alt="Progetto portfolio 2">
              <div class="portfolio-tags">
                <span class="portfolio-tag">3D</span>
                <span class="portfolio-tag">VFX</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto 02</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
            <article class="portfolio-item bottom-left">
              <img src="/images/portfolio-cover-03-695x391.jpg" alt="Progetto portfolio 3">
              <div class="portfolio-tags">
                <span class="portfolio-tag">Regia</span>
                <span class="portfolio-tag">2D</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto 03</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
            <article class="portfolio-item bottom-right">
              <img src="/images/portfolio-cover-04-695x391.jpg" alt="Progetto portfolio 4">
              <div class="portfolio-tags">
                <span class="portfolio-tag">Animazione</span>
                <span class="portfolio-tag">3D</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto 04</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
            <article class="portfolio-item wide">
              <img src="/images/portfolio-cover-05-695x391.jpg" alt="Progetto portfolio in evidenza">
              <div class="portfolio-tags">
                <span class="portfolio-tag">Regia</span>
                <span class="portfolio-tag">VFX</span>
                <span class="portfolio-tag">3D</span>
              </div>
              <div class="portfolio-overlay">
                <h3>Progetto In Evidenza</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
              </div>
            </article>
          </div>
          <div class="text-center mt-4">
            <a href="#" class="btn btn-cta btn-cta--blue btn-pill portfolio-cta">SCOPRI DI PI&Ugrave;</a>
          </div>
        </div>
      </section>
  
      <section id="paneblog" class="section-space pt-0">
        <div class="container">
          <h2 class="section-title section-title-reveal">
          <span class="section-title-text">PANEBLOG</span>
          <img class="section-title-sticker" src="/images/pensieri che ci frullano in testa.png" alt="" aria-hidden="true">
        </h2>
          <div class="row g-3">
            <div class="col-12 col-sm-6 col-lg-4">
              <article class="card blog-card h-100">
                <img src="/images/paneblog-cover-01-356x217.png" alt="Articolo blog 1">
                <div class="card-body">
                  <h3 class="blog-title">Dietro le quinte di Caramelle</h3>
                  <p class="blog-date">21 FEB 2026</p>
                  <p class="blog-abstract">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer in cursus erat.</p>
                  <a class="blog-link" href="#">
                    Leggi di pi&ugrave; <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
              <article class="card blog-card h-100">
                <img src="/images/paneblog-cover-02-356x217.png" alt="Articolo blog 2">
                <div class="card-body">
                  <h3 class="blog-title">Pipeline 3D: workflow interno</h3>
                  <p class="blog-date">15 FEB 2026</p>
                  <p class="blog-abstract">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer in cursus erat.</p>
                  <a class="blog-link" href="#">
                    Leggi di pi&ugrave; <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
              <article class="card blog-card h-100">
                <img src="/images/paneblog-cover-03-356x217.png" alt="Articolo blog 3">
                <div class="card-body">
                  <h3 class="blog-title">Regia e animazione: come si integrano</h3>
                  <p class="blog-date">08 FEB 2026</p>
                  <p class="blog-abstract">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer in cursus erat.</p>
                  <a class="blog-link" href="#">
                    Leggi di pi&ugrave; <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
          </div>
          <div class="text-center mt-4">
            <a href="#" class="btn btn-cta btn-cta--blue btn-pill">LEGGI IL PANEBLOG</a>
          </div>
        </div>
      </section>
    </main>
  
    <footer id="contatti" class="footer-cta">
      <div class="container">
        <div class="row g-4 footer-main align-items-center">
          <div class="col-lg-4">
            <img class="footer-logo" src="/images/panebarco logo light.png" alt="Panebarco">
            <p class="contact-line mb-0">Panebarco &amp; C. S.r.l. - Via Molino, 9<br>48121 Ravenna, Italia<br>+39 0544 35012 | +39 338 3693558<br>info@panebarco.it</p>
          </div>
  
          <div class="col-lg-3">
            <div class="social-row">
              <a class="social-circle social-facebook" href="#" aria-label="Facebook">
                <i class="bi bi-facebook"></i>
              </a>
              <a class="social-circle social-instagram" href="#" aria-label="Instagram">
                <i class="bi bi-instagram"></i>
              </a>
              <a class="social-circle social-vimeo" href="#" aria-label="Vimeo">
                <i class="bi bi-vimeo"></i>
              </a>
            </div>
            <p class="legal-line">Codice SDI XL13LG4<br>P. Iva e C. F. IT01315670396<br>R.E.A. RA 135428<br>Capitale sociale euro 40.000,00 I.V.</p>
          </div>
  
          <div class="col-lg-5">
            <h3 class="footer-heading">Hai un progetto in mente?<br><span class="footer-heading-strong">Lo animiamo noi.</span></h3>
            <a href="#" class="btn btn-cta btn-cta--orange btn-pill">CONTATTACI</a>
          </div>
        </div>
  
        <div class="footer-meta">
                  <p class="small-muted mb-0">
            Copyright &copy; Panebarco &amp; C. 2025 | <a href="#">Privacy Policy</a> - <a href="#">Cookie Policy</a>
          </p>
        </div>
      </div>
  
      <div class="footer-signature">
        <div class="container">
          Prodotto originale frutto delle menti felici e creative di
          <a href="https://www.happyminds.it" target="_blank" rel="noopener noreferrer">HappyMinds</a>
        </div>
      </div>
    </footer>
</BaseLayout>
