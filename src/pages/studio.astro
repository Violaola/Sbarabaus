---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="Studio - Panebarco" useInnerPagesScript={true} useInnerStyles={true}>
  <SiteHeader logoSrc="/images/panebarco logo light.png" containerClass="hero-fluid" />
  <MenuOverlay />
    <main>
      <section class="page-hero">
        <video autoplay muted loop playsinline preload="metadata" aria-hidden="true">
          <source src="/images/1021768637.mp4" type="video/mp4">
        </video>
        <div class="page-hero-content">
          <div class="page-hero-text">
            <p class="page-hero-bgword">LA TANA</p>
            <h1 class="page-hero-title">LO STUDIO</h1>
            <p class="page-hero-subtitle">Idee al confine tra cartoon e realtà</p>
          </div>
          <div class="page-hero-media">
            <img src="/images/testata img.png" alt="Studio">
          </div>
        </div>
      </section>
  
      <section class="page-main">
        <div class="inner">
          <h2>Storia di un'azienda mutante</h2>
        </div>
      </section>
    </main>
      <SiteFooter />
</BaseLayout>
