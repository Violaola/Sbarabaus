---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Layout title="Servizi - Panebarco" useInnerPagesScript={true} useInnerStyles={true}>
  <SiteHeader containerClass="hero-fluid" />
    <main>
      <section class="page-hero">
        <video autoplay muted loop playsinline preload="metadata" aria-hidden="true">
          <source src="/images/1021768637.mp4" type="video/mp4">
        </video>
        <div class="page-hero-content">
          <div class="page-hero-text">
            <p class="page-hero-bgword">COSA SAPPIAMO FARE</p>
            <h1 class="page-hero-title">SERVIZI</h1>
            <p class="page-hero-subtitle">Soluzioni creative dalla regia alla post-produzione</p>
          </div>
          <div class="page-hero-media">
            <img src="/images/testata img.png" alt="Servizi">
          </div>
        </div>
      </section>
  
      <section class="page-main">
        <div class="container">
          <h2>Commercials, Post-produzione, Service</h2>
        </div>
      </section>
    </main>
      <SiteFooter />
</Layout>