---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";

const specialProjects = [
  {
    title: "Curiosità e formati laterali",
    href: "/paneblog",
    image: "/images/curiosita-01.jpg",
    summary: "Contenuti nati per sperimentare linguaggi, toni e usi fuori dal perimetro più istituzionale.",
    tags: ["Special projects", "Format"],
  },
  {
    title: "Progetti editoriali e di racconto",
    href: "/paneblog/diario-di-viaggio",
    image: "/images/curiosita-02.jpg",
    summary: "Appunti visivi, materiali narrativi e piccoli mondi che tengono insieme processo, tono e identità.",
    tags: ["Editoriale", "Storytelling"],
  },
  {
    title: "Contenuti per librerie e archivi",
    href: "/portfolio",
    image: "/images/curiosita-03.jpg",
    summary: "Materiali modulari pensati per vivere su più canali, nel tempo, con una logica di collezione e riuso.",
    tags: ["Library", "Content"],
  },
] as const;

const mindItems = [
  {
    title: "Paneblog",
    href: "/paneblog",
    image: "/images/paneblog-cover-01-356x217.png",
    summary: "Appunti, dietro le quinte e pensieri che diventano racconto.",
    cta: "Apri il Paneblog",
  },
  {
    title: "Diario di viaggio",
    href: "/paneblog/diario-di-viaggio",
    image: "/images/paneblog-cover-02-356x217.png",
    summary: "Una rotta più libera, dove i progetti si intrecciano a tappe, incontri e processi.",
    cta: "Leggi il diario",
  },
  {
    title: "Newsletter",
    href: "/contatti",
    image: "/images/paneblog-cover-03-356x217.png",
    summary: "Una selezione ragionata di novità, work in progress e contenuti da tenere d'occhio.",
    cta: "Richiedila",
  },
] as const;
---

<Layout
  title="...E tanto altro - Panebarco"
  useInnerStyles={true}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="studio-page extras-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/1021768637.mp4"
      bgWord="ALTRE STORIE"
      title="...E TANTO ALTRO"
      subtitle="Progetti speciali, contenuti laterali e idee che tengono vivo il laboratorio"
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
    />

    <section class="page-main page-main--studio extras-intro">
      <div class="container">
        <div class="row g-4 g-xl-5 align-items-center">
          <div class="col-12 col-xl-7">
            <div class="extras-intro-copy">
              <h2 class="page-title-uniform">Qui finiscono le etichette e iniziano le deviazioni interessanti.</h2>
              <p>
                Oltre ai servizi più riconoscibili ci sono territori che usiamo per allargare il linguaggio, testare idee,
                costruire contenuti editoriali e mettere in circolo materiali che non stanno in una sola categoria.
              </p>
              <p>
                È uno spazio più aperto, ma non meno progettato: raccoglie progetti speciali, contenuti laterali, strumenti
                per raccontarci meglio e una libreria viva di cose che possono tornare utili anche ad altri.
              </p>
            </div>
          </div>

          <div class="col-12 col-xl-5">
            <div class="extras-intro-art">
              <img class="img-fluid d-block mx-auto" src="/images/paneblog-pensieri.png" alt="Pensieri che ci frullano in testa">
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft extras-special-projects" aria-labelledby="specialProjectsTitle">
      <div class="container">
        <div class="row justify-content-center text-center mb-2 mb-lg-3">
          <div class="col-12 col-xl-8">
            <h2 id="specialProjectsTitle" class="page-title-uniform">Progetti speciali</h2>
            <p class="extras-section-intro mb-0">
              Formati ibridi, iniziative editoriali, contenuti nati per testare nuove direzioni o tenere insieme materiali che
              meritano una vita più lunga e meno prevedibile.
            </p>
            <div class="mt-3 mt-lg-4">
              <a class="btn btn-cta btn-cta--blue btn-pill" href="/contatti">Parliamone</a>
            </div>
          </div>
        </div>

        <div class="row g-4">
          {specialProjects.map((item) => (
            <div class="col-12 col-md-6 col-xl-4">
              <a class="extras-case-card d-block h-100 text-decoration-none" href={item.href}>
                <div class="ratio ratio-4x3 extras-case-card__media">
                  <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                </div>
                <div class="extras-case-card__body">
                  <div class="extras-case-card__tags" aria-hidden="true">
                    {item.tags.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-space extras-mind" aria-labelledby="extrasMindTitle">
      <div class="container">
        <div class="row justify-content-center text-center mb-2 mb-lg-3">
          <div class="col-12 col-xl-8">
            <h2 id="extrasMindTitle" class="page-title-uniform">Pensieri che ci frullano in testa</h2>
            <p class="extras-section-intro">
              Tre porte d'accesso ai contenuti più editoriali: il Paneblog, il diario di viaggio e una newsletter pensata per
              chi vuole seguire quello che stiamo mettendo in moto.
            </p>
          </div>
        </div>

        <div class="row g-4 mt-2 mt-lg-3">
          {mindItems.map((item) => (
            <div class="col-12 col-md-6 col-xl-4">
              <article class="extras-mind-card extras-case-card h-100">
                <div class="ratio ratio-16x9 extras-mind-card__media">
                  <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                </div>
                <div class="extras-mind-card__body">
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                  <a class="btn btn-cta btn-cta--blue btn-pill mt-auto" href={item.href}>{item.cta}</a>
                </div>
              </article>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft extras-social-library">
      <div class="container">
        <div class="extras-social-library__inner">
          <div class="row g-4 g-lg-5 align-items-center">
            <div class="col-12 col-lg-7">
              <div class="extras-social-library__copy">
                <h2 class="page-title-uniform">Panebarco Social Library</h2>
                <p>
                  Una raccolta in movimento di contenuti, frammenti, materiali e piccoli formati da usare come archivio vivo:
                  utile per raccontare meglio il lavoro, attivare conversazioni e dare continuità ai progetti anche fuori dal set.
                </p>
                <a class="btn btn-cta btn-cta--blue btn-pill" href="/contatti">Chiedici la social library</a>
              </div>
            </div>

            <div class="col-12 col-lg-5">
              <div class="extras-social-library__stack">
                <img class="extras-social-library__card extras-social-library__card--one" src="/images/curiosita-01.jpg" alt="">
                <img class="extras-social-library__card extras-social-library__card--two" src="/images/curiosita-02.jpg" alt="">
                <img class="extras-social-library__card extras-social-library__card--three" src="/images/curiosita-03.jpg" alt="">
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--tight pt-2 pt-md-3 pt-lg-4">
      <div class="container">
        <ContactCtaBanner
          kicker="Hai in mente un formato meno prevedibile?"
          title="LO COSTRUIAMO NOI."
        />
      </div>
    </section>
  </main>
</Layout>
