---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import OriginalsShowcase from "../../components/OriginalsShowcase.astro";
import mainScriptUrl from "../../scripts/main.js?url";

const serviceAreas = [
  {
    title: "Commercials e Brand Video",
    href: "/servizi/commercials",
    videoSrc: "/images/panebarco-commercial-video.mp4",
    poster: "/images/hero-commercials.png",
    summary:
      "Realizziamo video animati per brand e istituzioni: definiamo stile, tecnica e tono, sviluppiamo lo script e produciamo spot efficaci, riconoscibili e flessibili nel budget.",
    bullets: [
      "Sviluppo script e concept",
      "Scelta di stile, tecnica e tono",
      "Spot animati e brand video",
      "Produzioni flessibili nel budget",
    ],
    buttonLabel: "Scopri commercials",
  },
  {
    title: "Post-produzione",
    href: "/servizi/post-produzione",
    videoSrc: "/images/1021768637.mp4",
    poster: "/images/compositing-e-visual-effects-01.jpg",
    summary:
      "Curare l’ultimo miglio è la nostra specialità: montaggio, 3D, VFX, compositing, integrazione live action e color grading per un risultato impeccabile.",
    bullets: [
      "Montaggio e finishing",
      "3D, VFX e compositing",
      "Integrazione live action",
      "Color grading e rifinitura finale",
    ],
    buttonLabel: "Scopri la post",
  },
  {
    title: "Service e Produzione Esecutiva",
    href: "/servizi/service",
    videoSrc: "/images/panebarco-studio-video.mp4",
    poster: "/images/servizi-cover-03-340x487.jpg",
    summary:
      "Accompagniamo produzioni animate in ogni fase, dalla pre-produzione alla post, integrandoci nei tuoi flussi con qualità, continuità e gestione operativa.",
    bullets: [
      "Supporto dalla pre alla post",
      "Integrazione nei flussi esistenti",
      "Coordinamento operativo",
      "Continuità di processo e qualità",
    ],
    buttonLabel: "Scopri il service",
  },
  {
    title: "Originals",
    href: "/originals",
    videoSrc: "/images/1021768637.mp4",
    poster: "/images/hero-dettaglio-originals.jpg",
    summary:
      "Siamo una casa di produzione indipendente con centinaia di IP originali, tra sviluppo, produzione e distribuzione. Cerchiamo partner per nuovi progetti audiovisivi.",
    bullets: [
      "IP originali in sviluppo",
      "Progetti in produzione",
      "Titoli pronti alla distribuzione",
      "Ricerca di partner e coproduzioni",
    ],
    buttonLabel: "Scopri originals",
  },
] as const;

const clientLogos = [
  {
    src: "/images/panebarco-logo-dark.png",
    alt: "Panebarco",
  },
  {
    src: "/images/logo-emilia-romagna-film-commision.png",
    alt: "Emilia-Romagna Film Commission",
  },
] as const;

const repeatedClientLogos = Array.from({ length: 3 }, (_, groupIndex) =>
  clientLogos.map((logo) => ({
    ...logo,
    isDuplicate: groupIndex > 0,
  }))
).flat();
---

<Layout
  title="Servizi - Panebarco"
  useInnerStyles={true}
  headerProps={{ containerClass: "hero-fluid" }}
>
    <main class="studio-page services-page">
      <HeroStyStudio
        backgroundVideoSrc="/images/1021768637.mp4"
        bgWord="COSE"
        title="SERVIZI"
        subtitle="Cose che sappiamo fare"
        sideImageSrc="/images/lo-studio-panebarco-teams.png"
        sideImageAlt="Team Panebarco"
        className="hero-sty-studio page-hero page-hero--studio"
      />

      

      <section id="servizi" class=" mt-5 section-space section-space--soft services-home-cards">
        <div class="container mt-md-5 pt-5">
          <h2 class="section-title section-title-reveal">
            <span class="section-title-text">SERVIZI</span>
            <img class="section-title-sticker" src="/images/cose che sappiamo fare.png" alt="" aria-hidden="true">
          </h2>
          <div class="row g-4 g-xxl-5 services-editorial-grid">
            {serviceAreas.map((service) => (
              <div class="col-12 col-xl-6">
                <article class="service-editorial-card h-100">
                  <div class="service-editorial-card__inner h-100">
                    <h3>{service.title}</h3>
                    <p class="service-editorial-summary">{service.summary}</p>

                    <div class="service-editorial-video ratio ratio-16x9 rounded-4 overflow-hidden">
                      <video autoplay muted loop playsinline preload="metadata" poster={service.poster}>
                        <source src={service.videoSrc} type="video/mp4" />
                      </video>
                    </div>

                    <ul class="service-editorial-list list-unstyled">
                      {service.bullets.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>

                    <div class="mt-auto pt-2">
                      <a class="btn btn-cta btn-cta--blue btn-pill" href={service.href}>
                        {service.buttonLabel}
                      </a>
                    </div>
                  </div>
                </article>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="services-clients section-space section-space--soft" aria-labelledby="servicesClientsTitle">
        <div class="container">
          <div class="text-center services-clients-head">
            <h2 id="servicesClientsTitle" class="page-title-uniform">Loghi e collaborazioni</h2>
          </div>

          <div class="services-logos-marquee">
            <div class="services-logos-track">
              {repeatedClientLogos.map((logo) => (
                <div class="services-logo-item" aria-hidden={logo.isDuplicate ? "true" : undefined}>
                  <img src={logo.src} alt={logo.isDuplicate ? "" : logo.alt} loading="lazy" decoding="async" />
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <OriginalsShowcase sectionId="servizi-originals" />

      <section class="studio-oscar-section section-space section-space--soft">
        <div class="container">
          <div class="row g-4 g-lg-5 align-items-start align-items-lg-center studio-oscar-grid">
            <div class="col-12 col-lg-5 studio-oscar-art">
              <img class="img-fluid d-block mx-auto mx-lg-0" src="/images/lo-studio-oscar.png" alt="Personaggi con Oscar">
            </div>
            <div class="col-12 col-lg-7 studio-oscar-copy text-start">
              <h2 class="page-title-uniform">
                Spoiler sul finale?
                <span>CI VEDIAMO AGLI OSCAR</span>
              </h2>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonummy nibh euismod
                tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim
              </p>
              <a class="btn btn-cta btn-cta--blue btn-pill" href="/studio/ci-vediamo-agli-oscar">Conosci i Panebarcos</a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script type="module" src={mainScriptUrl}></script>
</Layout>
