---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
---

<Layout
  title="Servizi - Panebarco"
  useInnerStyles={true}
  headerProps={{ containerClass: "hero-fluid" }}
>
    <main class="studio-page">
      <HeroStyStudio
        backgroundVideoSrc="/images/1021768637.mp4"
        bgWord="COSA SAPPIAMO FARE"
        title="SERVIZI"
        subtitle="Soluzioni creative dalla regia alla post-produzione"
        sideImageSrc="/images/lo-studio-panebarco-teams.png"
        sideImageAlt="Team Panebarco"
        className="hero-sty-studio page-hero page-hero--studio"
      />
  
      <section class="page-main page-main--studio">
        <div class="container">
          <h2>Commercials, Post-produzione, Service</h2>
        </div>
      </section>
    </main>
</Layout>
