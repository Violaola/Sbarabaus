---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import OriginalsShowcase from "../../components/OriginalsShowcase.astro";
import mainScriptUrl from "../../scripts/main.js?url";

const serviceAreas = [
  {
    title: "Commercials",
    href: "/servizi/commercials",
    image: "/images/servizi-cover-01-340x487.png",
    summary: "Spot, branded content e video pensati per raccontare, spiegare, promuovere e coinvolgere.",
  },
  {
    title: "Post-produzione",
    href: "/servizi/post-produzione",
    image: "/images/servizi-cover-02-340x487.jpg",
    summary: "Color, compositing, VFX e finishing per dare ritmo, atmosfera e precisione alle immagini.",
  },
  {
    title: "Service",
    href: "/servizi/service",
    image: "/images/servizi-cover-03-340x487.jpg",
    summary: "Supporto produttivo e operativo per accompagnare ogni fase del lavoro, dalla partenza alla consegna.",
  },
  {
    title: "...e tanto altro",
    href: "/servizi/e-tanto-altro",
    image: "/images/servizi-cover-01-340x487.png",
    summary: "Progetti speciali, sperimentazioni e idee laterali che allargano il nostro modo di lavorare.",
  },
] as const;

const clientLogos = [
  {
    src: "/images/panebarco-logo-dark.png",
    alt: "Panebarco",
  },
  {
    src: "/images/logo-emilia-romagna-film-commision.png",
    alt: "Emilia-Romagna Film Commission",
  },
] as const;

const repeatedClientLogos = Array.from({ length: 3 }, (_, groupIndex) =>
  clientLogos.map((logo) => ({
    ...logo,
    isDuplicate: groupIndex > 0,
  }))
).flat();
---

<Layout
  title="Servizi - Panebarco"
  useInnerStyles={true}
  headerProps={{ containerClass: "hero-fluid" }}
>
    <main class="studio-page services-page">
      <HeroStyStudio
        backgroundVideoSrc="/images/1021768637.mp4"
        bgWord="COSA SAPPIAMO FARE"
        title="SERVIZI"
        subtitle="Soluzioni creative dalla regia alla post-produzione"
        sideImageSrc="/images/lo-studio-panebarco-teams.png"
        sideImageAlt="Team Panebarco"
        className="hero-sty-studio page-hero page-hero--studio"
      />

      <section class="page-main page-main--studio services-hub-intro">
        <div class="container">
          <div class="row g-4 g-xl-5 align-items-center">
            <div class="col-12 col-lg-6">
              <div class="services-intro-copy">
                <h2 class="page-title-uniform">Un hub semplice per capire dove possiamo esserti utili.</h2>
                <p>
                  Lavoriamo tra narrazione, produzione e rifinitura, costruendo ogni progetto con un approccio
                  artigianale, flessibile e molto concreto. Qui trovi i quattro ambiti che organizzano il nostro
                  modo di lavorare.
                </p>
                <ul class="services-bullets list-unstyled">
                  <li><span class="fw-bold">Commercials</span> per raccontare, spiegare, promuovere e coinvolgere.</li>
                  <li><span class="fw-bold">Post-produzione</span> per integrare, trasformare, rifinire e potenziare le immagini.</li>
                  <li><span class="fw-bold">Service</span> per supporto creativo, produttivo e organizzativo.</li>
                  <li><span class="fw-bold">...e tanto altro</span> per progetti speciali, contenuti trasversali e sperimentazioni.</li>
                </ul>
              </div>
            </div>

            <div class="col-12 col-lg-6">
              <div class="services-intro-video ratio ratio-16x9 rounded-4 overflow-hidden shadow-sm">
                <video autoplay muted loop playsinline preload="metadata" poster="/images/servizi-cose.png">
                  <source src="/images/1021768637.mp4" type="video/mp4" />
                </video>
              </div>
            </div>
          </div>

        </div>
      </section>

      <section id="servizi" class="section-space section-space--soft services-home-cards">
        <div class="container">
          <h2 class="section-title section-title-reveal">
            <span class="section-title-text">SERVIZI</span>
            <img class="section-title-sticker" src="/images/cose che sappiamo fare.png" alt="" aria-hidden="true">
          </h2>
          <div class="row g-4 services-box-grid">
            {serviceAreas.map((service) => (
              <div class="col-12 col-md-6 col-lg-3">
                <a
                  class="services-box-link d-block text-decoration-none"
                  href={service.href}
                  aria-label={`Apri la pagina ${service.title}`}
                >
                  <article class="services-box-card" style={`--service-bg:url('${service.image}');`}>
                    <div class="services-box-card__overlay"></div>
                    <div class="services-box-card__content">
                      <h3>{service.title}</h3>
                      <p>{service.summary}</p>
                    </div>
                  </article>
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="services-clients section-space section-space--soft" aria-labelledby="servicesClientsTitle">
        <div class="container">
          <div class="text-center services-clients-head">
            <h2 id="servicesClientsTitle" class="page-title-uniform">Loghi e collaborazioni</h2>
          </div>

          <div class="services-logos-marquee">
            <div class="services-logos-track">
              {repeatedClientLogos.map((logo) => (
                <div class="services-logo-item" aria-hidden={logo.isDuplicate ? "true" : undefined}>
                  <img src={logo.src} alt={logo.isDuplicate ? "" : logo.alt} loading="lazy" decoding="async" />
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <OriginalsShowcase sectionId="servizi-originals" />

      <section class="studio-oscar-section section-space section-space--soft">
        <div class="container">
          <div class="row g-4 g-lg-5 align-items-start align-items-lg-center studio-oscar-grid">
            <div class="col-12 col-lg-5 studio-oscar-art">
              <img class="img-fluid d-block mx-auto mx-lg-0" src="/images/lo-studio-oscar.png" alt="Personaggi con Oscar">
            </div>
            <div class="col-12 col-lg-7 studio-oscar-copy text-start">
              <h2 class="page-title-uniform">
                Spoiler sul finale?
                <span>CI VEDIAMO AGLI OSCAR</span>
              </h2>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonummy nibh euismod
                tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim
              </p>
              <a class="btn btn-cta btn-cta--blue btn-pill" href="/studio/ci-vediamo-agli-oscar">Conosci i Panebarcos</a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script type="module" src={mainScriptUrl}></script>
</Layout>

<style>
  .services-page .services-hub-intro {
    overflow: hidden;
  }

  .services-page .services-intro-copy h2 {
    margin-bottom: 1rem;
  }

  .services-page .services-bullets {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 2rem;
    padding: 0;
  }

  .services-page .services-bullets li {
    position: relative;
    padding-left: 1.45rem;
    margin: 0;
  }

  .services-page .services-bullets li::before {
    content: "";
    position: absolute;
    top: 0.52rem;
    left: 0;
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 50%;
    background: var(--bs-warning);
    box-shadow: 0 0 0 0.2rem rgba(var(--bs-warning-rgb), 0.22);
  }

  .services-page .services-intro-video {
    background: #0f1115;
  }

  .services-page .services-intro-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .services-page .services-clients-head h2 {
    color: var(--ink);
  }

  .services-page .services-logos-marquee {
    overflow: hidden;
    position: relative;
    margin-top: clamp(1.75rem, 3vw, 2.5rem);
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.6);
    padding: 1.2rem 0;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  .services-page .services-logos-marquee::before,
  .services-page .services-logos-marquee::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(2rem, 8vw, 7rem);
    z-index: 1;
    pointer-events: none;
  }

  .services-page .services-logos-marquee::before {
    left: 0;
    background: linear-gradient(90deg, var(--bg) 0%, rgba(243, 244, 246, 0) 100%);
  }

  .services-page .services-logos-marquee::after {
    right: 0;
    background: linear-gradient(270deg, var(--bg) 0%, rgba(243, 244, 246, 0) 100%);
  }

  .services-page .services-logos-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: services-logo-scroll 22s linear infinite;
  }

  .services-page .services-logo-item {
    flex: 0 0 auto;
    width: clamp(12rem, 18vw, 16rem);
    min-height: 5rem;
    display: grid;
    place-items: center;
    padding: 1rem clamp(1rem, 2vw, 1.8rem);
  }

  .services-page .services-logo-item img {
    max-width: 100%;
    max-height: 3.6rem;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.84;
  }

  @keyframes services-logo-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-33.3333%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-page .services-logos-track {
      animation: none;
    }
  }

  @media (max-width: 767.98px) {
    .services-page .services-logos-marquee {
      padding-block: 1rem;
    }

    .services-page .services-logo-item {
      width: 11rem;
      min-height: 4.4rem;
    }
  }
</style>
