---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";

const interventionAreas = [
  {
    title: "Integrare",
    description: "3D e VFX integrati con riprese live action.",
    image: "/images/compositing-e-visual-effects-01.jpg",
  },
  {
    title: "Trasformare",
    description: "Compositing, effetti visivi e particellari.",
    image: "/images/rendering-a-livelli-01.jpg",
  },
  {
    title: "Rifinire",
    description: "Color grading, finishing, look & feel.",
    image: "/images/rendering-finale-01.jpg",
  },
  {
    title: "Potenziare",
    description: "Interventi invisibili a supporto della narrazione.",
    image: "/images/background-e-props-02.jpg",
  },
] as const;

const relatedCases = [
  {
    title: "Vita dura per gli Orsi Marsicani",
    href: "/portfolio/vita-dura-per-gli-orsi-marsicani",
    image: "/images/rendering-a-livelli-02.jpg",
    summary: "Un progetto in cui integrazione CGI e live action si tengono insieme fino all'ultimo frame.",
    tags: ["3D", "Live action"],
  },
  {
    title: "Caramelle",
    href: "/originals/caramelle",
    image: "/images/rendering-finale-02.jpg",
    summary: "Look, compositing e resa finale lavorano insieme per dare coerenza emotiva alle immagini.",
    tags: ["Finishing", "Look dev"],
  },
  {
    title: "Storyboard & Animatic",
    href: "/originals/caramelle",
    image: "/images/storyboard-e-animatic-01.jpg",
    summary: "Quando la rifinitura visiva parte da una pipeline ben costruita e continua fino alla consegna.",
    tags: ["Pipeline", "Final frame"],
  },
  {
    title: "Commercials",
    href: "/servizi/commercials",
    image: "/images/compositing-e-visual-effects-01.jpg",
    summary: "Spot e brand video in cui la post-produzione diventa ritmo, tono e precisione narrativa.",
    tags: ["Brand video", "VFX"],
  },
] as const;
---

<Layout
  title="Post-produzione - Panebarco"
  useInnerStyles={true}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="studio-page commercials-page post-production-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/1021768637.mp4"
      bgWord="FINISHING"
      title="POST-PRODUZIONE"
      subtitle="Integrare, trasformare, rifinire e potenziare le immagini"
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
    />

    <section class="studio-oscar-section section-space section-space--soft postpro-top-intro">
      <div class="container">
        <div class="row g-4 g-lg-5 align-items-start align-items-lg-center studio-oscar-grid">
          <div class="col-12 col-lg-5 studio-oscar-art">
            <img class="img-fluid d-block mx-auto mx-lg-0" src="/images/lo-studio-oscar.png" alt="Personaggi con Oscar">
          </div>
          <div class="col-12 col-lg-7 studio-oscar-copy text-start">
            <h2 class="page-title-uniform">
              POST-PRODUZIONE
              <span>APPROCCIO</span>
            </h2>
            <p>
              Da anni collaboriamo con case di produzione, post-produzione e agenzie per realizzare spot, opener, ident e
              progetti che richiedono interventi avanzati. Gestiamo modellazione e animazione 3D, integrazione con riprese,
              keying, compositing, VFX, effetti particellari e color grading, curando ogni dettaglio della fase finale per
              un risultato impeccabile.
            </p>
            <a class="btn btn-cta btn-cta--blue btn-pill" href="/studio">Scopri il nostro approccio</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft postpro-areas" aria-labelledby="postProAreasTitle">
      <div class="container">
        <div class="row justify-content-center text-center">
          <div class="col-12 col-xl-8">
            <h2 id="postProAreasTitle" class="page-title-uniform">Ambiti di intervento</h2>
            <p class="postpro-section-intro">
              Quattro modi in cui la post-produzione entra nel progetto: per unire livelli diversi, trasformare il visibile,
              rifinire il tono o sostenere la narrazione con interventi quasi invisibili.
            </p>
          </div>
        </div>

        <div class="row g-4 mt-1">
          {interventionAreas.map((area, index) => (
            <div class="col-12 col-md-6">
              <article class="postpro-area-card postpro-case-card h-100">
                <div class="ratio ratio-16x9 postpro-area-card__media">
                  <img src={area.image} alt={area.title} loading="lazy" decoding="async" />
                </div>
                <div class="postpro-area-card__body">
                  <p class="postpro-area-card__index">{String(index + 1).padStart(2, "0")}</p>
                  <h3>{area.title}</h3>
                  <p>{area.description}</p>
                </div>
              </article>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-space postpro-cases mb-4 mb-lg-5" aria-labelledby="postProCasesTitle">
      <div class="container">
        <div class="row g-3 align-items-end mb-2 mb-lg-3">
          <div class="col-12 col-lg-8">
            <h2 id="postProCasesTitle" class="page-title-uniform">Case history correlate</h2>
            <p class="postpro-section-intro postpro-section-intro--left mb-0">
              Alcuni lavori in cui integrazione, compositing, look e rifinitura diventano parte concreta del risultato finale.
            </p>
          </div>
        </div>

        <div class="row g-4">
          {relatedCases.map((item) => (
            <div class="col-12 col-md-6 col-xl-3">
              <a class="postpro-case-card d-block h-100 text-decoration-none" href={item.href}>
                <div class="ratio ratio-4x3 postpro-case-card__media">
                  <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                </div>
                <div class="postpro-case-card__body">
                  <div class="postpro-case-card__tags" aria-hidden="true">
                    {item.tags.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-space section-space--tight pt-2 pt-md-3 pt-lg-4">
      <div class="container">
        <ContactCtaBanner
          kicker="Hai già il materiale o il progetto è in corso?"
          title="LO RIFINIAMO NOI."
        />
      </div>
    </section>
  </main>
</Layout>
