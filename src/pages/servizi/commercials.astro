---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import commercialsPageScriptUrl from "../../scripts/pages/commercials.js?url";

// I 4 cluster narrativi mostrati nella sezione "modi per comunicare".
const communicationModes = [
  "Raccontare",
  "Spiegare",
  "Promuovere",
  "Coinvolgere",
];

// Libreria immagini per ciascun cluster; ogni blocco usa 4 frame.
const modeImageSets = {
  Raccontare: [
    "/images/raccontare-01.jpg",
    "/images/raccontare-02.jpg",
    "/images/raccontare-03.jpg",
    "/images/raccontare-04.jpg",
  ],
  Spiegare: [
    "/images/spiegare-01.png",
    "/images/spiegare-02.png",
    "/images/spiegare-03.png",
    "/images/spiegare-04.png",
  ],
  Promuovere: [
    "/images/promuovere-01.png",
    "/images/promuovere-02.png",
    "/images/promuovere-03.png",
    "/images/promuovere-04.png",
  ],
  Coinvolgere: [
    "/images/coinvolgere-01.jpg",
    "/images/coinvolgere-02.jpg",
    "/images/coinvolgere-03.jpg",
    "/images/coinvolgere-04.jpg",
  ],
} as const;

// Sticker grafico associato al titolo di ciascun cluster.
const modeBubbleSets = {
  Raccontare: "/images/raccontare.png",
  Spiegare: "/images/spiegare.png",
  Promuovere: "/images/promuovere.png",
  Coinvolgere: "/images/coinvolgere.png",
} as const;
---

<Layout
  title="Commercials - Panebarco"
  useInnerStyles={true}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="commercials-page studio-page">
    <!-- Hero di pagina con componente riutilizzabile -->
    <HeroStyStudio
      backgroundVideoSrc="/images/panebarco-commercial-video.mp4"
      bgWord="SERVIZI"
      title="COMMERCIALS"
      subtitle="Lorem ipsum dolor sit amet"
      sideImageSrc="/images/hero-commercials.png"
      sideImageAlt="Hero commercials"
    />

    <!-- Intro editoriale della sezione commercials -->
    <section class="page-main page-main--studio">
      <div class="w-100">
        <div class="container">
          <div class="row">
            <div class="col-12 text-lg-center text-start">
              <h2 class="page-title-uniform mb-4 text-body">Lorem ipsum dolor sit amet</h2>
              <p class="mb-4">
                Quis aute iure reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                Excepteur sint obcaecat cupiditat non proident, sunt in culpa qui officia deserunt mollit anim id
                est laborum.
              </p>
              <p class="mb-0">
                Quis aute iure reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                Excepteur sint obcaecat cupiditat non proident, sunt in culpa qui officia deserunt mollit anim id
                est laborum.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Griglia dinamica: un blocco per ogni modalità comunicativa -->
    <section class="section-space section-space--tight pt-0">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <h2 class="page-title-uniform text-primary mb-5 text-lg-center">QUATTRO MODI PER COMUNICARE.</h2>
            {communicationModes.map((mode, index) => {
              const scenes = modeImageSets[mode as keyof typeof modeImageSets] ?? [
                `https://placehold.co/620x300/png?text=${mode}+01`,
                `https://placehold.co/620x300/png?text=${mode}+02`,
                `https://placehold.co/460x280/png?text=${mode}+03`,
                `https://placehold.co/760x340/png?text=${mode}+04`,
              ];
              const bubble = modeBubbleSets[mode as keyof typeof modeBubbleSets];

              return (
              <article class:list={[index > 0 && "mt-5 pt-2", index === communicationModes.length - 1 && "mb-4 pb-4 mb-md-5 pb-md-4"]}>
                <!-- Titolo modalità + bubble decorativa animata -->
                <div class="commercial-mode-heading" data-commercial-mode-heading>
                  <h3 class="fw-bold text-body display-5 display-lg-4">{mode}</h3>
                  {bubble && (
                    <img
                      class="commercial-mode-bubble"
                      src={bubble}
                      alt=""
                      aria-hidden="true"
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <p>
                  Lorem ipsum dolor sit amet, consectetur adipiscing elit. Duis voluptate neque eget felis posuere
                  mattis, sed et enim at nulla iaculis interdum. Suspendisse sed elit at sem rutrum molestie.
                </p>

                <!-- Set di 4 card media con overlay informativo al focus/hover -->
                <div class="row g-3">
                  <div class="col-12 col-md-6">
                    <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 1`}>
                      <img
                        class="img-fluid w-100"
                        src={scenes[0]}
                        alt={`${mode} scena 1`}
                        style="height: 300px; object-fit: cover;"
                      />
                      <div class="commercials-media-tags" aria-hidden="true">
                        <span class="commercials-media-tag">{mode}</span>
                        <span class="commercials-media-tag">Commercial</span>
                      </div>
                      <div class="commercials-media-overlay" aria-hidden="true">
                        <h4>{mode} 01</h4>
                        <p>Frame dal progetto {mode.toLowerCase()}.</p>
                      </div>
                    </article>
                  </div>
                  <div class="col-12 col-md-6">
                    <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 2`}>
                      <img
                        class="img-fluid w-100"
                        src={scenes[1]}
                        alt={`${mode} scena 2`}
                        style="height: 300px; object-fit: cover;"
                      />
                      <div class="commercials-media-tags" aria-hidden="true">
                        <span class="commercials-media-tag">{mode}</span>
                        <span class="commercials-media-tag">Commercial</span>
                      </div>
                      <div class="commercials-media-overlay" aria-hidden="true">
                        <h4>{mode} 02</h4>
                        <p>Frame dal progetto {mode.toLowerCase()}.</p>
                      </div>
                    </article>
                  </div>
                  <div class="col-12 col-md-5">
                    <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 3`}>
                      <img
                        class="img-fluid w-100"
                        src={scenes[2]}
                        alt={`${mode} scena 3`}
                        style="height: 240px; object-fit: cover;"
                      />
                      <div class="commercials-media-tags" aria-hidden="true">
                        <span class="commercials-media-tag">{mode}</span>
                        <span class="commercials-media-tag">Commercial</span>
                      </div>
                      <div class="commercials-media-overlay" aria-hidden="true">
                        <h4>{mode} 03</h4>
                        <p>Frame dal progetto {mode.toLowerCase()}.</p>
                      </div>
                    </article>
                  </div>
                  <div class="col-12 col-md-7">
                    <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 4`}>
                      <img
                        class="img-fluid w-100"
                        src={scenes[3]}
                        alt={`${mode} scena 4`}
                        style="height: 240px; object-fit: cover;"
                      />
                      <div class="commercials-media-tags" aria-hidden="true">
                        <span class="commercials-media-tag">{mode}</span>
                        <span class="commercials-media-tag">Commercial</span>
                      </div>
                      <div class="commercials-media-overlay" aria-hidden="true">
                        <h4>{mode} 04</h4>
                        <p>Frame dal progetto {mode.toLowerCase()}.</p>
                      </div>
                    </article>
                  </div>
                </div>
              </article>
            )})}

            <!-- CTA finale verso pagina contatti -->
            <section class="mt-4 mt-md-5 pt-2 pt-md-4">
              <ContactCtaBanner
                kicker="Hai un progetto in mente?"
                title="LO ANIMIAMO NOI."
              />
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script type="module" src={commercialsPageScriptUrl}></script>
</Layout>
