              />
            </div>
          </div>
          <div class="col">
            <div class="ratio ratio-16x9 shadow-lg overflow-hidden">
              <img
                src="/images/curiosita-03.jpg"
                class="w-100 h-100 object-fit-cover"
                alt="Curiosità 3"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Credits -->
    <section class="section-space section-space--soft credits-section">
      <div class="container">
        <hr class="credits-divider mt-0 mb-5" />
        <div class="row">
          <div class="col-12 col-xl-11 credits-copy">
            <h2 class="page-title-uniform text-white text-uppercase mb-4">Credits</h2>
            <p class="credits-title mb-3 fst-italic">“Caramelle”</p>
            <p class="credits-text mb-2"><strong>regia</strong> di Matteo Panebarco</p>
            <p class="credits-text mb-2">è una produzione Panebarco in associazione con Mediterraneo Cinematografica per una WeShort Originals.</p>
            <p class="credits-text mb-5">Una distribuzione Prem1ere film.</p>
            <p class="credits-text mb-4 mb-md-5">Il film è sostenuto dalla Regione Emilia Romagna attraverso Emilia-Romagna Film Commission, Ministero della Cultura e Comune di Ravenna.</p>
