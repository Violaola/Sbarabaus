---
import Layout from "../../layouts/Layout.astro";
import HeroStyDettaglio from "../../components/HeroStyDettaglio.astro";

export function getStaticPaths() {
  const originals = [
    {
      slugOrig: "caramelle",
      title: "Caramelle",
    },
  ] as const;

  return originals.map((project) => ({
    params: { slugOrig: project.slugOrig },
    props: { project },
  }));
}

const { project } = Astro.props;

const sliderExtraSlides = [
  [
    { src: "https://placehold.co/900x675/png?text=Sketch+01", alt: "Sketch 1" },
    { src: "https://placehold.co/900x675/png?text=Sketch+02", alt: "Sketch 2" },
    { src: "https://placehold.co/900x675/png?text=Sketch+03", alt: "Sketch 3" },
  ],
  [
    { src: "https://placehold.co/900x675/png?text=Prop+01", alt: "Prop 1" },
    { src: "https://placehold.co/900x675/png?text=Prop+02", alt: "Prop 2" },
    { src: "https://placehold.co/900x675/png?text=Prop+03", alt: "Prop 3" },
  ],
];

const backgroundPropsSlides = [
  [
    { src: "/images/background-e-props-01.jpg", alt: "Background e Props 1" },
    { src: "/images/background-e-props-02.jpg", alt: "Background e Props 2" },
    { src: "/images/background-e-props-03.jpg", alt: "Background e Props 3" },
  ],
  ...sliderExtraSlides,
];
const backgroundPropsCards = backgroundPropsSlides.flat();

const renderingLevelsSlides = [
  [
    { src: "/images/rendering-a-livelli-01.jpg", alt: "Rendering a livelli 1" },
    { src: "/images/rendering-a-livelli-02.jpg", alt: "Rendering a livelli 2" },
    { src: "/images/rendering-a-livelli-03.jpg", alt: "Rendering a livelli 3" },
  ],
  ...sliderExtraSlides,
];
const renderingLevelsCards = renderingLevelsSlides.flat();
---

<Layout
  title={`${project.title} - Panebarco Originals`}
  description={`Dettaglio progetto Originals: ${project.title}`}
  useInnerStyles={true}
  headerProps={{
    containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5",
  }}
>
  <HeroStyDettaglio
    className="originals-hero"
    imageSrc="/images/caramelle-intro.jpg"
    imageAlt={`Frame progetto ${project.title}`}
  />

  <section class="section-space section-space--soft intro-header">
    <div class="container">
      <div class="row">
        <div class="col-12 col-lg-8 col-xl-7">
          <p class="hero-eyebrow mb-1">CINEMA E AUDIOVISIVO</p>
          <h1 class="heading-detail mb-1">Caramelle</h1>
          <p class="hero-meta mb-3">INIZIO PRODUZIONE 2025 · 12'</p>
          <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="pill pill-primary">Panebarco Originals</span>
            <span class="pill pill-neutral">3D</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main class="original-detail-page pb-5">
    <!-- Sinossi -->
    <section class="section-space section-space--soft">
      <div class="container">
        <div class="row">
          <div class="col-12 col-xl-12">
            <p class="lead text-white mb-3 fw-bold">
              “Caramelle” è stato proiettato in anteprima ad ottobre all’interno
              di Alice nella Città, sezione parallela della Festa del Cinema di
              Roma aggiudicandosi il Premio del Pubblico come Miglior Corto.
            </p>
            <p class="text-white mb-3 fw-bold">
              “Caramelle” nasce da una leggenda di Rimini. La storia parla di un
              padre che scompare all’improvviso e la famiglia resta divisa fra
              nostalgia, rabbia e incredulità, ma la figlia non smette di
              trovare caramelle, proprio come quando lui era vivo e gliele
              nascondeva in casa.
            </p>
            <p class="text-white mb-0 fw-bold">
              La storia parla di un uomo che scompare all’improvviso e la
              famiglia resta divisa fra nostalgia, rabbia e incredulità, ma la
              figlia non smette di trovare caramelle in tutta la casa. Le trova
              anche al mare, in mezzo alle conchiglie. Proprio come quando lui
              era vivo e gliele nascondeva dappertutto. Un misterioso tappeto di
              caramelle porta la bambina a scoprire cosa è accaduto. Il finale è
              sorprendente e commovente, un crescendo emotivo che catapulta lo
              spettatore all’interno di quel tappeto di caramelle colorate, fino
              a scoprire che il mistero è l’intuizione che richiama cioè la
              memoria affettiva personale.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Still principale -->
    <section id="guarda-il-corto" class="section-space section-space--tight">
      <div class="container">
        <div class="ratio ratio-16x9  shadow-lg overflow-hidden">
          <img
            class="w-100 h-100 object-fit-cover"
            src="/images/caramelle-intro.jpg"
            alt={`Still principale ${project.title}`}
          />
        </div>
      </div>
    </section>

    <!-- Personaggi -->
    <section class="section-space">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">Personaggi</h2>
        <p class="mb-4 text-white mb-0 fw-bold">
          Voluptatem laudantium in in. Nam natus magni quaerat et dolores facere deserunt. Ut consequatur perspiciatis eaque dolor et. Dolor natus voluptatem nobis similique. Suscipit molestiae vel vel sint sint earum fuga. Amet recusandae sunt. Voluptatum tempora voluptatem odit id harum aut quo perferendis. Sit voluptas similique.
        </p>
        <div class="row g-3 row-cols-1 row-cols-sm-2 row-cols-lg-3 originals-characters-grid">
          <div class="col">
            <div class="ratio ratio-4x3 char-card">
              <img class="w-100 h-100 object-fit-cover" src="/images/personaggi-01.jpg" alt="Personaggio 1" />
            </div>
          </div>
          <div class="col">
            <div class="ratio ratio-4x3 char-card">
              <img class="w-100 h-100 object-fit-cover" src="/images/personaggi-02.jpg" alt="Personaggio 2" />
            </div>
          </div>
          <div class="col">
            <div class="ratio ratio-4x3 char-card">
              <img class="w-100 h-100 object-fit-cover" src="/images/personaggi-03.jpg" alt="Personaggio 3" />
            </div>
          </div>
          <div class="col">
            <div class="ratio ratio-4x3 char-card">
              <img class="w-100 h-100 object-fit-cover" src="/images/personaggi-04.jpg" alt="Personaggio 4" />
            </div>
          </div>
          <div class="col">
            <div class="ratio ratio-4x3 char-card">
              <img class="w-100 h-100 object-fit-cover" src="/images/personaggi-05.jpg" alt="Personaggio 5" />
            </div>
          </div>
          <div class="col">
            <div class="ratio ratio-4x3 char-card">
              <img class="w-100 h-100 object-fit-cover" src="/images/personaggi-06.jpg" alt="Personaggio 6" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Background e Props -->
    <section class="section-space section-space--soft">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">Background e Props</h2>
        <div
          id="renderingLevelsCarouselDesktop"
          class="carousel slide frecce-slider-dettaglio js-bgprops-carousel d-none d-md-block"
          data-bs-ride="false"
          data-bs-touch="true"
        >
          <div class="carousel-inner">
            {backgroundPropsSlides.map((slide, slideIndex) => (
              <div class:list={["carousel-item", slideIndex === 0 && "active"]}>
                <div class="row g-3 mx-0">
                  {slide.map((card) => (
                    <div class="col-4">
                      <div class="ratio ratio-4x3 bgprops-card rounded-0">
                        <img src={card.src} class="w-100 h-100 object-fit-cover" alt={card.alt} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#renderingLevelsCarouselDesktop" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#renderingLevelsCarouselDesktop" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
          <div class="carousel-indicators mt-3">
            {backgroundPropsSlides.map((_, slideIndex) => (
              <button
                type="button"
                data-bs-target="#renderingLevelsCarouselDesktop"
                data-bs-slide-to={slideIndex}
                class:list={[slideIndex === 0 && "active"]}
                aria-label={`Slide ${slideIndex + 1}`}
              ></button>
            ))}
          </div>
        </div>

        <div
          id="renderingLevelsCarouselMobile"
          class="carousel slide frecce-slider-dettaglio js-bgprops-carousel d-md-none"
          data-bs-ride="false"
          data-bs-touch="true"
        >
          <div class="carousel-inner">
            {backgroundPropsCards.map((card, cardIndex) => (
              <div class:list={["carousel-item px-2", cardIndex === 0 && "active"]}>
                <div class="ratio ratio-4x3 bgprops-card rounded-0">
                  <img src={card.src} class="w-100 h-100 object-fit-cover" alt={card.alt} />
                </div>
              </div>
            ))}
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#renderingLevelsCarouselMobile" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#renderingLevelsCarouselMobile" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </div>
    </section>

    <!-- Storyboard & Animatic -->
    <section class="section-space section-space--tight">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">
          Storyboard & Animatic
        </h2>
        <p>Voluptatem laudantium in in. Nam natus magni quaerat et dolores facere deserunt. Ut consequatur perspiciatis eaque dolor et. Dolor natus voluptatem nobis similique. Suscipit molestiae vel vel sint sint earum fuga.   Amet recusandae sunt. Voluptatum tempora voluptatem odit id harum aut quo perferendis. Sit voluptas similique.</p>
        <div class="row g-3 row-cols-1 row-cols-md-3">
          <div class="col">
            <div class="ratio ratio-16x9 shadow-lg overflow-hidden">
              <img
                src="/images/storyboard-e-animatic-01.jpg"
                class="w-100 h-100 object-fit-cover"
                alt="Distribuzione 1"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Rendering a livelli -->
     <section class="section-space section-space--soft">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">Rendering a livelli</h2>
        <div
          id="bgPropsCarouselDesktop"
          class="carousel slide frecce-slider-dettaglio js-bgprops-carousel d-none d-md-block"
          data-bs-ride="false"
          data-bs-touch="true"
        >
          <div class="carousel-inner">
            {renderingLevelsSlides.map((slide, slideIndex) => (
              <div class:list={["carousel-item", slideIndex === 0 && "active"]}>
                <div class="row g-3 mx-0">
                  {slide.map((card) => (
                    <div class="col-4">
                      <div class="ratio ratio-4x3 bgprops-card rounded-0">
                        <img src={card.src} class="w-100 h-100 object-fit-cover" alt={card.alt} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#bgPropsCarouselDesktop" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#bgPropsCarouselDesktop" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
          <div class="carousel-indicators mt-3">
            {renderingLevelsSlides.map((_, slideIndex) => (
              <button
                type="button"
                data-bs-target="#bgPropsCarouselDesktop"
                data-bs-slide-to={slideIndex}
                class:list={[slideIndex === 0 && "active"]}
                aria-label={`Slide ${slideIndex + 1}`}
              ></button>
            ))}
          </div>
        </div>

        <div
          id="bgPropsCarouselMobile"
          class="carousel slide frecce-slider-dettaglio js-bgprops-carousel d-md-none"
          data-bs-ride="false"
          data-bs-touch="true"
        >
          <div class="carousel-inner">
            {renderingLevelsCards.map((card, cardIndex) => (
              <div class:list={["carousel-item px-2", cardIndex === 0 && "active"]}>
                <div class="ratio ratio-4x3 bgprops-card rounded-0">
                  <img src={card.src} class="w-100 h-100 object-fit-cover" alt={card.alt} />
                </div>
              </div>
            ))}
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#bgPropsCarouselMobile" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#bgPropsCarouselMobile" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </div>
    </section>

    <!-- Compositing e Visual Effects -->
    <section class="section-space section-space--tight">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">
          Compositing e Visual Effects
        </h2>
        <div class="row g-3 row-cols-1 row-cols-md-3">
          <div class="col">
            <div class="ratio ratio-16x9 shadow-lg overflow-hidden">
              <img
                src="/images/compositing-e-visual-effects-01.jpg"
                class="w-100 h-100 object-fit-cover"
                alt="Comp 1"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Rendering finale -->
    <section class="section-space section-space--tight">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">
          Rendering finale
        </h2>
        <p>Eos illum cupiditate aspernatur. Distinctio porro laborum. Reiciendis ad ipsa et hic maiores consectetur quo ipsum et.   Sapiente est eveniet illo et explicabo in. Amet eligendi sequi dignissimos quo. Natus tempore suscipit nihil neque. Et praesentium consequatur similique perspiciatis ipsum cupiditate tempora et. Nemo sequi in excepturi repudiandae dicta. Dicta a reiciendis aspernatur fuga.   Deserunt illum cupiditate omnis ipsa. Ut fugit impedit ut exercitationem fugit cum recusandae quia. Hic sunt ut recusandae fugit.</p>
        <div class="row g-3 row-cols-1 row-cols-md-3">
          <div class="col">
            <div class="ratio ratio-16x9 shadow-lg overflow-hidden">
              <img
                src="/images/rendering-finale-01.jpg"
                class="w-100 h-100 object-fit-cover"
                alt="Comp 1"
              />
            </div>
          </div>
          <div class="col">
            <div class="ratio ratio-16x9 shadow-lg overflow-hidden">
              <img
                src="/images/rendering-finale-02.jpg"
                class="w-100 h-100 object-fit-cover"
                alt="Comp 2"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Distribuzione -->
    <section class="section-space section-space--tight">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">
          Distribuzione
        </h2>
        <p>Voluptatem laudantium in in. Nam natus magni quaerat et dolores facere deserunt. Ut consequatur perspiciatis eaque dolor et. Dolor natus voluptatem nobis similique. Suscipit molestiae vel vel sint sint earum fuga.   Amet recusandae sunt. Voluptatum tempora voluptatem odit id harum aut quo perferendis. Sit voluptas similique.</p>
        <div class="row g-3 row-cols-1 row-cols-md-3">
          <div class="col">
            <div class="ratio ratio-16x9 shadow-lg overflow-hidden">
              <img
                src="/images/distribuzione-01.jpg"
                class="w-100 h-100 object-fit-cover"
                alt="Comp 1"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Curiosità -->
    <section class="section-space section-space--tight">
      <div class="container">
        <h2 class="page-title-uniform text-white mb-4">
          Curiosità
        </h2>
        <p>Voluptatem laudantium in in. Nam natus magni quaerat et dolores facere deserunt. Ut consequatur perspiciatis eaque dolor et. Dolor natus voluptatem nobis similique. Suscipit molestiae vel vel sint sint earum fuga.   Amet recusandae sunt. Voluptatum tempora voluptatem odit id harum aut quo perferendis. Sit voluptas similique.</p>
        <div class="row g-3 row-cols-1 row-cols-md-3">
          <div class="col">
            <div class="ratio ratio-16x9 shadow-lg overflow-hidden">
              <img
                src="/images/curiosita-01.jpg"
                class="w-100 h-100 object-fit-cover"
                alt="Curiosità 1"
              />
