  </script>
</Layout>

<style lang="scss">
  :global(body.inner-page) {
    background: #000;
    color: #fff;
  }

  .intro-header {
    background: transparent;
  }

  .hero-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 800;
    font-size: 0.85rem;
    color: #9ca3af;
  }

  .hero-meta {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.95rem;
    font-weight: 700;
    color: #aeb4bd;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    font-weight: 800;
    letter-spacing: 0.04em;
    font-size: 0.95rem;
    line-height: 1;
  }

  .pill-primary {
    background: #009FE3;
    color: #eaf6ff;
    box-shadow: none;
  }

  .pill-neutral {
    background: #f5f7fb;
    color: #0b0c0f;
  }

  .originals-hero__media {
    width: 100%;
    height: clamp(16rem, 52vh, 28rem);
    border-radius: 0;
  }

  @media (min-width: 768px) {
    .originals-hero__media {
      border-radius: 0.5rem;
    }
  }

  /* Personaggi cards */
  .originals-characters-grid .char-card {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #111;
  }

  .originals-characters-grid .char-card.no-radius {
    border-radius: 0;
  }

  .originals-characters-grid .char-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .originals-characters-grid .ratio-square {
    aspect-ratio: 1 / 1;
  }

  .originals-characters-grid .ratio-wide {
    aspect-ratio: 4 / 3;
  }

  .originals-characters-grid .ratio-wide-short {
    aspect-ratio: 16 / 9;
  }

  .originals-characters-grid .ratio-tall {
    aspect-ratio: 3 / 4;
  }

  /* Background e Props slider */
  .bgprops-card {
    background: #0f0f10;
    overflow: hidden;
  }

  .bgprops-card img {
    object-fit: cover;
  }


</style>
