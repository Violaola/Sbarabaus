---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import MenuOverlay from "../../components/MenuOverlay.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<BaseLayout title="Originals - Panebarco" useInnerPagesScript={true} useInnerStyles={true}>
  <SiteHeader containerClass="hero-fluid" />
  <MenuOverlay />
    <main>
      <section class="page-hero">
        <video autoplay muted loop playsinline preload="metadata" aria-hidden="true">
          <source src="/images/1021768637.mp4" type="video/mp4">
        </video>
        <div class="page-hero-content">
          <div class="page-hero-text">
            <p class="page-hero-bgword">PRODUZIONI INDIPENDENTI</p>
            <h1 class="page-hero-title">ORIGINALS</h1>
            <p class="page-hero-subtitle">Format originali sviluppati dentro la nostra casa creativa</p>
          </div>
          <div class="page-hero-media">
            <img src="/images/testata img.png" alt="Originals">
          </div>
        </div>
      </section>
  
      <section class="page-main">
        <div class="container">
          <h2>Universi originali Panebarco</h2>
        </div>
      </section>
    </main>
      <SiteFooter />
</BaseLayout>
