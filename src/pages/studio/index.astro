---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import studioPageScriptUrl from "../../scripts/pages/studio.js?url";
---

<Layout
  title="Studio - Panebarco"
  useInnerStyles={true}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
    <main class="studio-page">
      <!-- Hero dello Studio (componentizzata) -->
      <HeroStyStudio
        backgroundVideoSrc="/images/panebarco-studio-video.mp4"
        bgWord="LA TANA"
        title="LO STUDIO"
        subtitle="Idee al confine tra cartoon e realtà"
        sideImageSrc="/images/lo-studio-panebarco-teams.png"
        sideImageAlt="Team Panebarco"
      />
  
      <!-- Blocco storia introduttivo -->
      <section class="page-main page-main--studio">
        <div class="container">
          <div class="row g-4 g-xl-5 align-items-end studio-story">
            <div class="col-12 col-lg-7 studio-story-copy">
              <h2 class="page-title-uniform">Storia di un'azienda mutante</h2>
              <p>
                Duis in nibh egestas, facilisis magna ac, sagittis felis. Curabitur
                sagittis nisi non porttitor ullamcorper. Proin mattis, lacus eu
                condimentum dapibus, turpis lectus pellentesque mauris, vitae ornare
                nunc leo et justo.
              </p>
              <p>
                Pellentesque tempus elementum aliquet. Etiam commodo elit ut mi
                tristique laoreet. Donec ac enim vestibulum, sagittis urna sit amet,
                posuere ex.
              </p>
            </div>
            <div class="col-12 col-lg-5 studio-story-art text-lg-end">
              <img class="studio-story-intro-img img-fluid d-block ms-lg-auto" src="/images/lo-studio-img-intro.png" alt="Illustrazione intro lo studio">
            </div>
          </div>
        </div>
      </section>

      <!-- Timeline/slider storia azienda -->
      <section class="studio-timeline section-space">
        <div class="container">
          <h2 class="studio-timeline-title page-title-uniform" id="studioTimelineTitle">Questa è la storia di un’azienda mutante</h2>
          <div class="studio-timeline-track" data-studio-timeline>
            <button
              class="studio-timeline-arrow studio-timeline-arrow--prev"
              type="button"
              aria-label="Anno precedente"
              data-timeline-prev
            >
              <img src="/images/freccia-sinistra.png" alt="" aria-hidden="true">
            </button>

            <div class="studio-timeline-viewport" id="studioTimelineViewport" aria-labelledby="studioTimelineTitle">
              <div class="studio-timeline-slides">
                <article class="studio-timeline-card is-active">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 1976">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Gli inizi</h3>
                      <p>
                        Mauris nec orci sit amet nunc sodales pulvinar. Aliquam placerat, est a
                        vestibulum eleifend, ante nisl rhoncus ante, eu lacinia dui sem ut arcu.
                      </p>
                      <p>
                        Praesent aliquam interdum lectus, id imperdiet elit. Curabitur sagittis nisi
                        non porttitor ullamcorper, in fermentum lorem aliquet.
                      </p>
                    </div>
                  </div>
                </article>

                <article class="studio-timeline-card">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 1989">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Crescita creativa</h3>
                      <p>
                        Pellentesque tempus elementum aliquet. Etiam commodo elit ut mi tristique
                        laoreet. Donec ac enim vestibulum, sagittis urna sit amet, posuere ex.
                      </p>
                      <p>
                        Aenean lacinia bibendum nulla sed consectetur. Cras justo odio, dapibus ac
                        facilisis in, egestas eget quam.
                      </p>
                    </div>
                  </div>
                </article>

                <article class="studio-timeline-card">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 2003">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Nuove produzioni</h3>
                      <p>
                        Integer posuere erat a ante venenatis dapibus posuere velit aliquet. Maecenas
                        faucibus mollis interdum, sed posuere consectetur est at lobortis.
                      </p>
                      <p>
                        Vestibulum id ligula porta felis euismod semper. Nullam quis risus eget urna
                        mollis ornare vel eu leo.
                      </p>
                    </div>
                  </div>
                </article>

                <article class="studio-timeline-card">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 2024">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Nuove mutazioni</h3>
                      <p>
                        Donec sed odio dui. Sed posuere consectetur est at lobortis. Integer posuere
                        erat a ante venenatis dapibus posuere velit aliquet.
                      </p>
                      <p>
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi leo risus,
                        porta ac consectetur ac, vestibulum at eros.
                      </p>
                    </div>
                  </div>
                </article>
              </div>
            </div>

            <button
              class="studio-timeline-arrow studio-timeline-arrow--next"
              type="button"
              aria-label="Anno successivo"
              data-timeline-next
            >
              <img src="/images/freccia-destra.png" alt="" aria-hidden="true">
            </button>
          </div>

          <div class="studio-timeline-dots" role="tablist" aria-label="Seleziona una fase della storia">
            <button class="studio-timeline-dot is-active" type="button" aria-label="Vai al 1976" data-timeline-dot="0"></button>
            <button class="studio-timeline-dot" type="button" aria-label="Vai al 1989" data-timeline-dot="1"></button>
            <button class="studio-timeline-dot" type="button" aria-label="Vai al 2003" data-timeline-dot="2"></button>
            <button class="studio-timeline-dot" type="button" aria-label="Vai al 2024" data-timeline-dot="3"></button>
          </div>
        </div>
      </section>

      <section class="studio-panebarcos-intro section-space section-space--soft">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-12 col-xl-10 studio-panebarcos-intro-inner text-start text-md-center">
              <h2 class="page-title-uniform">I protagonisti siamo tutti noi... i Panebarcos</h2>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonummy nibh euismod
                tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="studio-panebarcos-photo py-0" aria-label="Il team Panebarcos">
        <div class="container-fluid px-0 position-relative">
          <img
            id="studioPanebarcosImage"
            class="img-fluid d-block w-100"
            src="/images/lo-studio-panebarcos-01.jpg"
            alt="Il team Panebarcos in studio"
            data-studio-panebarcos-image
          >
          <button
            class="studio-panebarcos-trigger position-absolute d-block m-2 m-md-4"
            type="button"
            aria-label="Mostra la foto successiva dei Panebarcos"
            aria-controls="studioPanebarcosImage"
            data-studio-panebarcos-trigger
            style="top:0; right:0; width:clamp(7rem, 22vw, 20rem); z-index:2;"
          >
            <img
              class="img-fluid d-block w-100"
              src="/images/studio-make-magic-happen.png"
              alt=""
              aria-hidden="true"
            >
          </button>
        </div>
      </section>

      <section class="studio-oscar-section section-space section-space--soft">
        <div class="container">
          <div class="row g-4 g-lg-5 align-items-start align-items-lg-center studio-oscar-grid">
            <div class="col-12 col-lg-5 studio-oscar-art">
              <img class="img-fluid d-block mx-auto mx-lg-0" src="/images/lo-studio-oscar.png" alt="Personaggi con Oscar">
            </div>
            <div class="col-12 col-lg-7 studio-oscar-copy text-start">
              <h2 class="page-title-uniform">
                Spoiler sul finale?
                <span>CI VEDIAMO AGLI OSCAR</span>
              </h2>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonummy nibh euismod
                tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim
              </p>
              <a class="btn btn-cta btn-cta--blue btn-pill" href="/studio/ci-vediamo-agli-oscar">Conosci i Panebarcos</a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script type="module" src={studioPageScriptUrl}></script>
</Layout>
