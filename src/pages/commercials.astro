---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
import SiteFooter from "../components/SiteFooter.astro";

const communicationModes = [
  "Raccontare",
  "Spiegare",
  "Promuovere",
  "Coinvolgere",
];

const modeImageSets = {
  Raccontare: [
    "/images/raccontare-01.jpg",
    "/images/raccontare-02.jpg",
    "/images/raccontare-03.jpg",
    "/images/raccontare-04.jpg",
  ],
  Spiegare: [
    "/images/spiegare-01.png",
    "/images/spiegare-02.png",
    "/images/spiegare-03.png",
    "/images/spiegare-04.png",
  ],
  Promuovere: [
    "/images/promuovere-01.png",
    "/images/promuovere-02.png",
    "/images/promuovere-03.png",
    "/images/promuovere-04.png",
  ],
  Coinvolgere: [
    "/images/coinvolgere-01.jpg",
    "/images/coinvolgere-02.jpg",
    "/images/coinvolgere-03.jpg",
    "/images/coinvolgere-04.jpg",
  ],
} as const;
---

<BaseLayout title="Commercials - Panebarco" useInnerPagesScript={true} useInnerStyles={true}>
  <SiteHeader
    logoSrc="/images/panebarco logo light.png"
    containerClass="container-fluid hero-fluid px-3 px-md-4 px-lg-5"
    menuIconSrc="/images/hamburger-menu-bianco.png"
  />
  <MenuOverlay />
  <main class="commercials-page studio-page">
    <section class="page-hero page-hero--studio">
      <div class="container page-hero-content page-hero-content--studio">
        <div class="row g-4 g-lg-5 align-items-end">
          <div class="col-12 col-lg-7 col-xl-6">
            <div class="page-hero-text">
              <p class="page-hero-bgword">SERVIZI</p>
              <h1 class="page-hero-title">COMMERCIALS</h1>
              <p class="page-hero-subtitle">Lorem ipsum dolor sit amet</p>
            </div>
          </div>
          <div class="col-12 col-lg-5 col-xl-6 text-lg-end">
            <div class="page-hero-media">
              <img class="img-fluid d-block ms-lg-auto" src="/images/hero-commercials.png" alt="Hero commercials">
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="page-main page-main--studio">
      <div class="w-100">
        <div class="container">
          <div class="row">
            <div class="col-12 text-center">
              <h2 class="page-title-uniform mb-4 text-body">Lorem ipsum dolor sit amet</h2>
              <p class="mb-4">
                Quis aute iure reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                Excepteur sint obcaecat cupiditat non proident, sunt in culpa qui officia deserunt mollit anim id
                est laborum.
              </p>
              <p class="mb-0">
                Quis aute iure reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                Excepteur sint obcaecat cupiditat non proident, sunt in culpa qui officia deserunt mollit anim id
                est laborum.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--tight pt-0">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <h2 class="page-title-uniform text-primary mb-5">QUATTRO MODI PER COMUNICARE.</h2>
            {communicationModes.map((mode, index) => {
              const scenes = modeImageSets[mode as keyof typeof modeImageSets] ?? [
                `https://placehold.co/620x300/png?text=${mode}+01`,
                `https://placehold.co/620x300/png?text=${mode}+02`,
                `https://placehold.co/460x280/png?text=${mode}+03`,
                `https://placehold.co/760x340/png?text=${mode}+04`,
              ];

              return (
              <article class:list={[index > 0 && "mt-5 pt-2", index === communicationModes.length - 1 && "mb-4 pb-4 mb-md-5 pb-md-4"]}>
                <h3 class="mb-2 fw-bold text-body display-5 display-lg-4">{mode}</h3>
                <p>
                  Lorem ipsum dolor sit amet, consectetur adipiscing elit. Duis voluptate neque eget felis posuere
                  mattis, sed et enim at nulla iaculis interdum. Suspendisse sed elit at sem rutrum molestie.
                </p>

                <div class="row g-3">
                  <div class="col-12 col-md-6">
                    <img
                      class="img-fluid w-100 rounded-4"
                      src={scenes[0]}
                      alt={`${mode} scena 1`}
                      style="height: 300px; object-fit: cover;"
                    />
                  </div>
                  <div class="col-12 col-md-6">
                    <img
                      class="img-fluid w-100 rounded-4"
                      src={scenes[1]}
                      alt={`${mode} scena 2`}
                      style="height: 300px; object-fit: cover;"
                    />
                  </div>
                  <div class="col-12 col-md-5">
                    <img
                      class="img-fluid w-100 rounded-4"
                      src={scenes[2]}
                      alt={`${mode} scena 3`}
                      style="height: 240px; object-fit: cover;"
                    />
                  </div>
                  <div class="col-12 col-md-7">
                    <img
                      class="img-fluid w-100 rounded-4"
                      src={scenes[3]}
                      alt={`${mode} scena 4`}
                      style="height: 240px; object-fit: cover;"
                    />
                  </div>
                </div>
              </article>
            )})}

            <section class="mt-4 mt-md-5 pt-2 pt-md-4">
              <div class="commercials-cta-card position-relative rounded-4">
                <img
                  class="commercials-cta-figure"
                  src="/images/lo-animiamo-noi.png"
                  alt="Mascotte Panebarco"
                />
                <div class="commercials-cta-copy text-white text-start">
                  <p class="commercials-cta-kicker mb-0 fw-bold fs-2 fs-lg-1 lh-1">Hai un progetto in mente?</p>
                  <h3 class="commercials-cta-title mt-1 mb-0 text-white fw-bolder text-uppercase display-5 display-lg-4 lh-1">LO ANIMIAMO NOI.</h3>
                  <a href="/contatti" class="btn btn-cta btn-cta--blue btn-pill mt-3">Contattaci</a>
                </div>
              </div>
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
