---
interface Props {
  imageSrc?: string;
  imageAlt?: string;
  ariaLabel?: string;
}

const {
  imageSrc = "/images/hero-dettaglio-originals.jpg",
  imageAlt = "Hero progetto Panebarco Originals",
  ariaLabel = "Hero progetto Originals",
} = Astro.props;
---

<section class="original-project-hero" aria-label={ariaLabel}>
  <div class="original-project-hero__frame">
    <img src={imageSrc} alt={imageAlt} loading="eager" decoding="async" />
  </div>
</section>

<style>
  .original-project-hero {
    display: flex;
    justify-content: center;
    padding: clamp(5.9rem, 11vh, 7.6rem) clamp(1rem, 3vw, 2.5rem)
      clamp(1.1rem, 2.5vw, 1.8rem);
  }

  .original-project-hero__frame {
    width: 70vw;
    height: 80vh;
    border: 1px solid rgba(0, 159, 227, 0.92);
    background: #000;
    overflow: hidden;
  }

  .original-project-hero__frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 991.98px) {
    .original-project-hero {
      padding-top: clamp(5.4rem, 10vw, 6.6rem);
    }

    .original-project-hero__frame {
      width: 86vw;
      height: min(66vh, 34rem);
    }
  }

  @media (max-width: 767.98px) {
    .original-project-hero {
      padding-top: clamp(5rem, 16vw, 6rem);
    }

    .original-project-hero__frame {
      width: 92vw;
      height: min(54vh, 24rem);
    }
  }
</style>
