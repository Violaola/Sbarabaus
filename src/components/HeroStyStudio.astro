---
interface Props {
  className?: string;
  backgroundVideoSrc?: string;
  bgWord?: string;
  title?: string;
  subtitle?: string;
  sideImageSrc?: string;
  sideImageAlt?: string;
}

const {
  className = "hero-sty-studio page-hero page-hero--studio",
  backgroundVideoSrc = "/images/panebarco-studio-video.mp4",
  bgWord = "LA TANA",
  title = "LO STUDIO",
  subtitle = "Idee al confine tra cartoon e realtà",
  sideImageSrc = "/images/lo-studio-panebarco-teams.png",
  sideImageAlt = "Team Panebarco",
} = Astro.props;
---

<section class={className}>
  {backgroundVideoSrc && (
    <video autoplay muted loop playsinline preload="metadata" aria-hidden="true">
      <source src={backgroundVideoSrc} type="video/mp4" />
    </video>
  )}

  <div class="container page-hero-content page-hero-content--studio">
    <div class="row g-4 g-lg-5 align-items-end">
      <div class="col-12 col-lg-7 col-xl-6">
        <div class="page-hero-text">
          <p class="page-hero-bgword">{bgWord}</p>
          <h1 class="page-hero-title">{title}</h1>
          <p class="page-hero-subtitle">{subtitle}</p>
        </div>
      </div>
      {sideImageSrc && (
        <div class="col-12 col-lg-5 col-xl-6 text-lg-end">
          <div class="page-hero-media">
            <img
              class="img-fluid d-block ms-lg-auto"
              src={sideImageSrc}
              alt={sideImageAlt}
            />
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero-sty-studio {
    position: relative;
    overflow: hidden;
  }

  .page-hero-media img {
    transform: translateY(clamp(6%, 8vw, 14%));
  }

  @media (max-width: 575.98px) {
    .page-hero-media img {
      transform: translateY(0);
    }
  }
</style>
