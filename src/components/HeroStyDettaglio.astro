---
interface Props {
  imageSrc: string;
  imageAlt?: string;
  caption?: string;
  className?: string;
  objectPosition?: string;
  show?: boolean;
  containerClass?: string;
  borderRadius?: string;
  heroHeight?: string;
}

const {
  imageSrc,
  imageAlt = "",
  caption,
  className = "hero-sty-dettaglio",
  objectPosition = "center",
  show = true,
  containerClass = "",
  borderRadius = "0",
  heroHeight = "80vh",
} = Astro.props;
---

{show && (
  <section
    class={className}
    style={`--hero-height:${heroHeight}; --hero-radius:${borderRadius}; --hero-obj-pos:${objectPosition};`}
  >
    <div class={`hero-sty-dettaglio__media ${containerClass}`}>
      <img src={imageSrc} alt={imageAlt} loading="eager" />
      {caption && <div class="hero-sty-dettaglio__caption">{caption}</div>}
    </div>
  </section>
)}

<style>
  .hero-sty-dettaglio {
    position: relative;
    padding: 0;
    margin: 0;
    width: 100%;
    min-height: var(--hero-height);
    overflow: hidden;
    background: transparent;
  }

  .hero-sty-dettaglio__media {
    position: relative;
    width: 100%;
    min-height: var(--hero-height);
    height: 100%;
    overflow: hidden;
    border-radius: var(--hero-radius);
  }

  .hero-sty-dettaglio__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-obj-pos);
    display: block;
  }

  .hero-sty-dettaglio__caption {
    position: absolute;
    left: 50%;
    bottom: clamp(0.75rem, 3vw, 1.5rem);
    transform: translateX(-50%);
    margin: 0;
    padding: 0.35rem 1rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.58);
    backdrop-filter: blur(6px) saturate(140%);
    color: var(--hero-caption-color, #fdfdfd);
    font-size: clamp(0.95rem, 1.3vw, 1.15rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.2;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.28);
  }

  @media (max-width: 768px) {
    .hero-sty-dettaglio {
      min-height: 75vh;
    }
    .hero-sty-dettaglio__media {
      min-height: 75vh;
    }
    .hero-sty-dettaglio__caption {
      bottom: clamp(0.4rem, 2.5vw, 0.8rem);
      padding: 0.25rem 0.8rem;
      font-size: clamp(0.9rem, 3vw, 1.05rem);
    }
  }
</style>
