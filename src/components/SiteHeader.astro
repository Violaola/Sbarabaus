---
interface Props {
  logoSrc?: string;
  logoHref?: string;
  logoAlt?: string;
  containerClass?: string;
  showLogo?: boolean;
  menuIconSrc?: string;
}

const {
  logoSrc = "/images/panebarco logo dark.png",
  logoHref = "/",
  logoAlt = "Panebarco",
  containerClass = "container-fluid hero-fluid px-3 px-md-4 px-lg-5",
  showLogo = true,
  menuIconSrc = "/images/hamburger-menu-bianco.png",
} = Astro.props;
---

<header class="top-header">
  <div class={containerClass}>
    <div class="hero-nav">
      <button class="menu-trigger" type="button" aria-label="Apri menu">
        {menuIconSrc ? (
          <img class="menu-trigger-icon" src={menuIconSrc} alt="" aria-hidden="true" />
        ) : (
          <>
            <span></span>
            <span></span>
            <span></span>
          </>
        )}
      </button>
      {showLogo && (
        <a href={logoHref} class="hero-logo text-decoration-none" aria-label="Panebarco">
          <img src={logoSrc} alt={logoAlt} />
        </a>
      )}
    </div>
  </div>
</header>
